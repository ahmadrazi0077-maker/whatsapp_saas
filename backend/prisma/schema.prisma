generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts     Contact[]
  campaigns    Campaign[]
  templates    Template[]
  chatbotRules ChatbotRule[]
  devices      Device[]
  media        Media[]
  teamMembers  TeamMember[]
  webhooks     Webhook[]
 chats Chat[]
 devices  ChatDevice[] 
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String
  email       String?
  tags        String[] @default([])
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id          String    @id @default(uuid())
  name        String
  message     String
  recipients  String[]  @default([])
  status      String    @default("draft")
  scheduledAt DateTime?
  sentAt      DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Template {
  id        String   @id @default(uuid())
  name      String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatbotRule {
  id        String   @id @default(uuid())
  keyword   String
  reply     String
  matchType String   @default("contains")
  active    Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String
  status      String   @default("disconnected")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats       ChatDevice[]   // ADD THIS LINE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  name      String
  type      String
  size      String
  url       String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  email     String
  role      String   @default("member")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String[] @default([])
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  author    String   @default("WhatsFlow Team")
  category  String   @default("General")
  tags      String[] @default([])
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Chat {
  id            String    @id @default(uuid())
  phoneNumber   String
  name          String
  lastMessage   String?
  lastMessageAt DateTime?
  tags          String[]  @default([])
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  devices       ChatDevice[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  sender    String
  content   String
  type      String   @default("text")
  mediaUrl  String?
  status    String   @default("sent")
  timestamp DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ChatDevice {
  id       String @id @default(uuid())
  chatId   String
  deviceId String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}
