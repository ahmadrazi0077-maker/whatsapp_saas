{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://whatsapp-saas-server.onrender.com",
    "NEXT_PUBLIC_SOCKET_URL": "https://whatsapp-saas-server.onrender.com"
  }
}
